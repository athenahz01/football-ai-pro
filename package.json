{
  "name": "football-ai-pro",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "etl": "tsx --env-file=.env.local scripts/etl.ts",
    "etl:verify": "tsx --env-file=.env.local scripts/etl.ts --verify-idempotency",
    "etl:competitions": "tsx --env-file=.env.local scripts/etl.ts --list-competitions",
    "eval": "node --conditions react-server --env-file=.env.local --import tsx eval/run-eval.ts",
    "test": "node --conditions react-server --env-file=.env.local --test --import tsx lib/sql/__tests__/guard.test.ts lib/sql/__tests__/executor.test.ts lib/retrieval/__tests__/glossary.test.ts lib/agent/__tests__/verify-grounding.test.ts lib/providers/__tests__/api-football.test.ts lib/agent/__tests__/answer-query-live.test.ts",
    "verify:api-football": "tsx --env-file=.env.local scripts/api-football-live.ts",
    "format": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.85",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "@types/pg": "^8.20.0",
    "@xenova/transformers": "^2.17.2",
    "ai": "^6.0.208",
    "next": "16.2.9",
    "node-sql-parser": "^5.4.0",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "three": "^0.184.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.184.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
