SUPABASE_URL=https://your-project.supabase.co
SUPABASE_DB_URL=postgresql://user:password@host:5432/postgres
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
DATA_PROVIDER=statsbomb_open

# Licensed commercial source. Required only when DATA_PROVIDER is api_football and
# live requests are made. Use the direct key from https://v3.football.api-sports.io
# with the x-apisports-key header, not the RapidAPI variant.
API_FOOTBALL_KEY=your-api-football-key

# Optional comma separated neutral competition ids. Leave blank to load everything.
ETL_COMPETITION_IDS=

# Public Supabase values for the browser auth client. These are safe to expose.
# Set them to the same project URL and anon key as above. Required for sign in.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Rate limits. Anonymous traffic is limited per IP, signed in users per user id
# with a higher allowance. All optional, shown with their defaults.
RATE_LIMIT_PER_MINUTE=12
RATE_LIMIT_PER_DAY=300
RATE_LIMIT_USER_PER_MINUTE=30
RATE_LIMIT_USER_PER_DAY=1000
